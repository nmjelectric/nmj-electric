---
import { company } from "../../data/company";
---

<section class="hero">
	<div class="content">
		<img
			src={company.logo.src}
			alt="NMJ Electric"
			class="logo"
		/>

		<h1>
			Reliable Electrical Services
			<span>Across the Dallas–Fort Worth Metroplex</span>
		</h1>

		<p>
			Residential and commercial electrical services performed by a
			licensed Texas Master Electrician.
		</p>

		<div class="buttons">
			<a class="primary" href="tel:8177430124">
				Call (817) 743-0124
			</a>

			<a class="secondary" href="/contact">
				Request a Quote
			</a>
		</div>
	</div>
</section>

<style>

.hero {
	min-height: clamp(38rem, calc(100vh - 68px), 52rem);
	padding: clamp(4rem, 8vw, 7rem) 1.5rem;

	display: flex;
	align-items: center;
	justify-content: center;

	box-sizing: border-box;
}

.content {
	width: 100%;
	max-width: 1000px;
	margin: 0 auto;
	text-align: center;
}

.logo {
	display: block;
	width: clamp(220px, 22vw, 340px);
	height: auto;
	margin: 0 auto clamp(2.5rem, 5vw, 4rem);
}

h1 {
	font-size: clamp(2.5rem, 5vw, 4rem);
	line-height: 1.1;
	margin: 0 0 1.5rem;
}

h1 span {
	display: block;
	margin-top: 0.75rem;

	color: #0f3d73;
	font-size: clamp(1.5rem, 3vw, 2.25rem);
	line-height: 1.2;
}

.content > p {
	max-width: 900px;
	margin: 0 auto 2rem;

	font-size: clamp(1rem, 1.7vw, 1.25rem);
	line-height: 1.6;
	color: #555;
}

.buttons {
	display: flex;
	justify-content: center;
	gap: 1rem;
	flex-wrap: wrap;
}

.primary,
.secondary {
	padding: 1rem 2rem;
	border-radius: 8px;
	text-decoration: none;
	font-weight: 700;
}

.primary {
	background: #0f3d73;
	color: white;
}

.secondary {
	border: 2px solid #0f3d73;
	color: #0f3d73;
}

@media (max-width: 600px) {
	.hero {
		min-height: auto;
		padding: 4rem 1.25rem;
	}

	.logo {
		width: clamp(180px, 60vw, 240px);
		margin-bottom: 2rem;
	}

	.buttons {
		flex-direction: column;
		align-items: stretch;
	}

	.primary,
	.secondary {
		width: 100%;
		box-sizing: border-box;
		text-align: center;
	}
}

</style>