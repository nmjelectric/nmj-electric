---
import { company } from "../../data/company";
import { navigation } from "../../data/navigation";
const currentPath = Astro.url.pathname;
---

<header>
	<div class="container">
		<a href="/" class="logo">NMJ Electric</a>

		<nav id="mobile-navigation" class="main-navigation" aria-label="Main navigation">
      {navigation.map((item) => (
        <a
          href={item.href}
          class:list={{ active: currentPath === item.href }}
        >
          {item.label}
        </a>
      ))}
    </nav>

		<a class="call-button" href={`tel:${company.phoneLink}`}>
    		Call {company.phoneDisplay}
		</a>

		<button
		class="menu-button"
		type="button"
		aria-label="Open navigation menu"
		aria-controls="mobile-navigation"
		aria-expanded="false"
		>
		<span></span>
		<span></span>
		<span></span>
		</button>

	</div>
</header>

<script>
  const menuButton = document.querySelector(".menu-button");
  const navigation = document.querySelector(".main-navigation");

  if (
    menuButton instanceof HTMLButtonElement &&
    navigation instanceof HTMLElement
  ) {
    menuButton.addEventListener("click", () => {
      const isOpen = navigation.classList.toggle("is-open");

      menuButton.setAttribute("aria-expanded", String(isOpen));
      menuButton.setAttribute(
        "aria-label",
        isOpen ? "Close navigation menu" : "Open navigation menu"
      );

      menuButton.classList.toggle("is-open", isOpen);
    });

    navigation.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", () => {
        navigation.classList.remove("is-open");
        menuButton.classList.remove("is-open");
        menuButton.setAttribute("aria-expanded", "false");
        menuButton.setAttribute("aria-label", "Open navigation menu");
      });
    });
  }
</script>

<style>
  /* -------------------------
     Desktop header
  ------------------------- */

  header {
    position: relative;
    z-index: 1000;
    background: white;
    border-bottom: 1px solid #ddd;
  }

  .container {
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    padding: 1rem 1.5rem;
    box-sizing: border-box;

    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
  }

  .logo {
    flex-shrink: 0;
    color: #111827;
    font-size: 1.4rem;
    font-weight: 700;
    text-decoration: none;
  }

  .main-navigation {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .main-navigation a {
    color: #374151;
    font-weight: 600;
    text-decoration: none;
    transition: color 150ms ease;
  }

  .main-navigation a:hover,
  .main-navigation a.active {
    color: #f7b719;
  }

  .call-button {
    flex-shrink: 0;
    padding: 0.75rem 1rem;
    border-radius: 6px;
    background: #0f3d73;
    color: white;
    font-weight: 700;
    text-decoration: none;
    white-space: nowrap;
  }

  /* Hidden on desktop */
  .menu-button {
    display: none;
  }

  /* -------------------------
     Mobile header
  ------------------------- */

  @media (max-width: 768px) {
    .container {
      padding: 1rem 1.25rem;
      gap: 1rem;
    }

    .logo {
      font-size: 1.25rem;
    }

    /* Hide phone button to make room for hamburger */
    .call-button {
      display: none;
    }

    .menu-button {
      display: flex;
      width: 44px;
      height: 44px;
      margin-left: auto;
      padding: 10px;
      border: 0;
      background: transparent;
      flex-direction: column;
      justify-content: center;
      gap: 5px;
      cursor: pointer;
    }

    .menu-button span {
      display: block;
      width: 24px;
      height: 2px;
      margin-inline: auto;
      border-radius: 999px;
      background: #111827;
      transition:
        transform 200ms ease,
        opacity 200ms ease;
    }

    .main-navigation {
      display: none;
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;

      padding: 0.75rem 1.25rem;
      background: white;
      border-top: 1px solid #ddd;
      box-shadow: 0 12px 24px rgba(0, 0, 0, 0.15);

      flex-direction: column;
      align-items: stretch;
      gap: 0;
    }

    .main-navigation.is-open {
      display: flex;
    }

    .main-navigation a {
      display: block;
      padding: 1rem 0.5rem;
      color: #374151;
      border-bottom: 1px solid #e5e7eb;
    }

    .main-navigation a:last-child {
      border-bottom: 0;
    }

    .menu-button.is-open span:nth-child(1) {
      transform: translateY(7px) rotate(45deg);
    }

    .menu-button.is-open span:nth-child(2) {
      opacity: 0;
    }

    .menu-button.is-open span:nth-child(3) {
      transform: translateY(-7px) rotate(-45deg);
    }
  }
</style>

