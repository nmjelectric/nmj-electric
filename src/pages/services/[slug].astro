---
import MainLayout from "../../layouts/MainLayout.astro";
import CallToAction from "../../components/home/CallToAction.astro";
import { services } from "../../data/services";

export function getStaticPaths() {
	return services.map((service) => ({
		params: {
			slug: service.slug,
		},
		props: {
			service,
		},
	}));
}

const { service } = Astro.props;
---

<MainLayout
	

	title={service.title}
	description={service.shortDescription}
>
	<section class="service-hero">
		<img
			src={service.heroImage.src}
			alt={service.title}
			class="service-hero-image"
		/>
		<div class="service-hero-overlay">
			<div class="service-hero-content">
				<p class="eyebrow">NMJ Electric Services</p>

				<h1>{service.heroTitle}</h1>

				<p>{service.heroText}</p>
			</div>
		</div>
	</section>

	<section class="service-content">
		<div class="service-description">
			<h2>How We Can Help</h2>

			<p>
				NMJ Electric provides professional {service.title.toLowerCase()} services
				throughout the Dallas–Fort Worth Metroplex.
			</p>

			<p>
				Every project receives clear communication, careful workmanship, and
				straightforward recommendations based on the needs of the property.
			</p>
		</div>

		<div class="service-list">
			<h2>Common Services</h2>

			<ul>
				{
					service.items.map((item) => (
						<li>{item}</li>
					))
				}
			</ul>
		</div>
	</section>

	<CallToAction />
</MainLayout>

<style>

	.service-hero {
		position: relative;
		height: 28rem;
		overflow: hidden;
		border-radius: 1rem;
		margin-bottom: 4rem;
	}

	.service-hero-image {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
	}

	.service-hero-overlay {
		position: absolute;
		inset: 0;

		display: flex;
		align-items: center;

		background:
			linear-gradient(
				90deg,
				rgba(0,0,0,.70),
				rgba(0,0,0,.35),
				rgba(0,0,0,.15)
			);
	}

	.service-hero-content {
		max-width: 700px;
		padding: 3rem;
		color: white;
	}

	.service-hero-content h1 {
		margin: .5rem 0 1rem;
		font-size: clamp(2.5rem, 5vw, 4rem);
		line-height: 1.1;
	}

	.service-hero-content p {
		font-size: 1.15rem;
		line-height: 1.7;
		max-width: 40rem;
	}

	.eyebrow {
		font-size: .9rem;
		font-weight: 700;
		letter-spacing: .08em;
		text-transform: uppercase;
		color: #F7B719;
	}

	@media (max-width: 768px) {

		.service-hero {
			height: 36rem;
		}

		.service-hero-content {
			padding: 2rem;
		}

		.service-hero-content h1 {
			font-size: 2.5rem;
		}
	}

	.service-hero {
		max-width: 900px;
		margin: 0 auto;
		padding: 2rem 1.5rem 2rem;
		text-align: center;
	}

	.eyebrow {
		color: #f59e0b;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.08em;
	}

	.service-hero h1 {
		font-size: clamp(2.5rem, 6vw, 4rem);
		margin-bottom: 1.5rem;
	}

	.service-hero > p:last-child {
		max-width: 750px;
		margin: 0 auto;
		font-size: 1.2rem;
		color: #4b5563;
		line-height: 1.7;
	}

	.service-content {
		max-width: 1100px;
		margin: 0 auto;
		padding: 2rem 1.5rem 5rem;
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 3rem;
	}

	.service-content h2 {
		font-size: 2rem;
		margin-top: 0;
	}

	.service-description p,
	.service-list li {
		color: #4b5563;
		font-size: 1.1rem;
		line-height: 1.7;
	}

	.service-list ul {
		margin: 0;
		padding-left: 1.25rem;
	}

	.service-list li {
		margin-bottom: 0.75rem;
	}

	@media (max-width: 700px) {
		.service-content {
			grid-template-columns: 1fr;
			gap: 2rem;
		}
	}
</style>