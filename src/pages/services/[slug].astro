---
import MainLayout from "../../layouts/MainLayout.astro";
import CallToAction from "../../components/home/CallToAction.astro";
import { services } from "../../data/services";

export function getStaticPaths() {
	return services.map((service) => ({
		params: {
			slug: service.slug,
		},
		props: {
			service,
		},
	}));
}

const { service } = Astro.props;
---

<MainLayout
	title={service.title}
	description={service.shortDescription}
>
	<section class="service-hero">
		<p class="eyebrow">NMJ Electric Services</p>
		<h1>{service.heroTitle}</h1>
		<p>{service.heroText}</p>
	</section>

	<section class="service-content">
		<div class="service-description">
			<h2>How We Can Help</h2>

			<p>
				NMJ Electric provides professional {service.title.toLowerCase()} services
				throughout the Dallas–Fort Worth Metroplex.
			</p>

			<p>
				Every project receives clear communication, careful workmanship, and
				straightforward recommendations based on the needs of the property.
			</p>
		</div>

		<div class="service-list">
			<h2>Common Services</h2>

			<ul>
				{
					service.items.map((item) => (
						<li>{item}</li>
					))
				}
			</ul>
		</div>
	</section>

	<CallToAction />
</MainLayout>

<style>
	.service-hero {
		max-width: 900px;
		margin: 0 auto;
		padding: 4rem 1.5rem 3rem;
		text-align: center;
	}

	.eyebrow {
		color: #f59e0b;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.08em;
	}

	.service-hero h1 {
		font-size: clamp(2.5rem, 6vw, 4rem);
		margin-bottom: 1.5rem;
	}

	.service-hero > p:last-child {
		max-width: 750px;
		margin: 0 auto;
		font-size: 1.2rem;
		color: #4b5563;
		line-height: 1.7;
	}

	.service-content {
		max-width: 1100px;
		margin: 0 auto;
		padding: 2rem 1.5rem 5rem;
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 3rem;
	}

	.service-content h2 {
		font-size: 2rem;
		margin-top: 0;
	}

	.service-description p,
	.service-list li {
		color: #4b5563;
		font-size: 1.1rem;
		line-height: 1.7;
	}

	.service-list ul {
		margin: 0;
		padding-left: 1.25rem;
	}

	.service-list li {
		margin-bottom: 0.75rem;
	}

	@media (max-width: 700px) {
		.service-content {
			grid-template-columns: 1fr;
			gap: 2rem;
		}
	}
</style>