---
import MainLayout from "../layouts/MainLayout.astro";
import { company } from "../data/company";
import LightingInstallation from "../assets/images/projects/resi-lighting-installation.jpg";
import ElectricalImprovements from "../assets/images/projects/electrical-improvements.jpg";
---

<MainLayout
	title="Projects"
	description={`View residential and commercial electrical projects completed by ${company.name}.`}
>
	<section class="projects-hero">
		<p class="eyebrow">Our Work</p>
		<h1>Electrical Projects</h1>
		<p>
			Explore residential and commercial electrical work completed by
			NMJ Electric throughout the Dallas–Fort Worth area.
		</p>
	</section>

	<section class="projects-grid">
		<article class="project-card">
			<div class="project-placeholder">
				<img src={LightingInstallation.src} alt="Lighting Installation" />
			</div>

			<div class="project-content">
				<p class="project-type">Residential</p>
				<h2>Lighting Installation</h2>
				<p>
					Professional lighting installation designed to improve
					function, safety, and appearance.
				</p>
			</div>
		</article>

		<article class="project-card">
			<div class="project-placeholder">
				<img src={ElectricalImprovements.src} alt="Electrical Improvements" />
			</div>

			<div class="project-content">
				<p class="project-type">Commercial</p>
				<h2>Electrical Improvements</h2>
				<p>
					Electrical upgrades and repairs completed with attention to
					safety, reliability, and workmanship.
				</p>
			</div>
		</article>
	</section>
</MainLayout>

<style>

    .project-placeholder {
        aspect-ratio: 4 / 3;
        overflow: hidden;
        background: #eeeeee;
    }

    .project-placeholder img {
        display: block;
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

	.projects-hero {
		max-width: 760px;
		margin: 0 auto;
		padding: 5rem 1.5rem 3rem;
		text-align: center;
	}

	.eyebrow {
		margin-bottom: 0.75rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.08em;
	}

	.projects-hero h1 {
		margin-bottom: 1rem;
		font-size: clamp(2.25rem, 6vw, 4rem);
	}

	.projects-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
		gap: 2rem;
		max-width: 1100px;
		margin: 0 auto;
		padding: 2rem 1.5rem 5rem;
	}

	.project-card {
		overflow: hidden;
		border: 1px solid #d7d7d7;
		border-radius: 0.75rem;
		background: #ffffff;
	}

	.project-placeholder {
		display: grid;
		min-height: 220px;
		place-items: center;
		background: #eeeeee;
		color: #555555;
		font-weight: 600;
	}

	.project-content {
		padding: 1.5rem;
	}

	.project-type {
		margin-bottom: 0.5rem;
		font-size: 0.875rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.06em;
	}

	.project-content h2 {
		margin-bottom: 0.75rem;
	}
</style>