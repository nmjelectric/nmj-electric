---
import Header from "../components/layout/Header.astro";
import Footer from "../components/layout/Footer.astro";
import "../styles/global.css";

interface Props {
	title: string;
	description?: string;
}

const {
	title,
	description = "Residential and commercial electrical services throughout the Dallas–Fort Worth area."
} = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<meta name="description" content={description} />
		<title>{title} | NMJ Electric</title>
	</head>

	<body>
		<Header />

		<main>
			<slot />
		</main>

		<Footer />
	</body>
</html>